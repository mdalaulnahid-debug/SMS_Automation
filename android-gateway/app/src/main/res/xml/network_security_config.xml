<?xml version="1.0" encoding="utf-8"?>
<!--
  Allow cleartext HTTP to the local backend server.
  The backend runs on a private LAN (192.168.x.x) over plain HTTP.
  This config permits cleartext only — all other traffic uses HTTPS.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>

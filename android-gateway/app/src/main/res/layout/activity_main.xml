<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_surface"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/bg_surface"
            app:title="SMS GATEWAY"
            app:titleTextColor="@color/text_primary"
            app:subtitleTextColor="@color/accent" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="32dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══ HERO ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_hero_gradient"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="52dp"
                android:paddingBottom="44dp">

                <!-- Status ring -->
                <FrameLayout
                    android:layout_width="164dp"
                    android:layout_height="164dp"
                    android:layout_gravity="center_horizontal">

                    <View
                        android:id="@+id/statusGlow"
                        android:layout_width="164dp"
                        android:layout_height="164dp"
                        android:background="@drawable/bg_status_indicator"
                        android:backgroundTint="@color/status_stopped_glow" />

                    <FrameLayout
                        android:layout_width="128dp"
                        android:layout_height="128dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_status_indicator"
                        android:backgroundTint="@color/bg_card">

                        <ImageView
                            android:id="@+id/statusIcon"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_sms_gateway"
                            android:contentDescription="Gateway status" />
                    </FrameLayout>
                </FrameLayout>

                <!-- Status label -->
                <TextView
                    android:id="@+id/tvServiceStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="STOPPED"
                    android:textColor="@color/danger"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.14" />

                <!-- Gateway ID pill -->
                <TextView
                    android:id="@+id/tvGatewayId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_elevated"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="5dp"
                    android:text="GP_PHONE_01"
                    android:textAppearance="@style/TextAppearance.SmsGateway.GatewayId" />

                <!-- Backend dot -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginTop="14dp">

                    <View
                        android:id="@+id/backendDot"
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:background="@drawable/bg_connection_dot" />

                    <TextView
                        android:id="@+id/tvBackendHealth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="7dp"
                        android:text="Backend: checking..."
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Start / Stop -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToggleService"
                    style="@style/Widget.SmsGateway.Button.Hero"
                    android:layout_width="240dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:text="Start Service" />

                <!-- Polling indicator — shown only when running -->
                <TextView
                    android:id="@+id/tvPollingStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="● Polling VPS · 3s interval"
                    android:textColor="@color/success"
                    android:textSize="12sp"
                    android:letterSpacing="0.04"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- ══ SIM SWITCHER (dual-SIM phones only) ══ -->
            <LinearLayout
                android:id="@+id/simSwitcher"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/btnSim1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="13dp"
                    android:paddingBottom="13dp"
                    android:background="@drawable/bg_sim1_active"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tvSim1Slot"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SIM 1"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.14"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/bg_primary" />

                    <TextView
                        android:id="@+id/tvSim1Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="SIM 1"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.01"
                        android:fontFamily="sans-serif"
                        android:textColor="@color/bg_primary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnSim2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="13dp"
                    android:paddingBottom="13dp"
                    android:background="@drawable/bg_sim2_inactive"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tvSim2Slot"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SIM 2"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.14"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/sim2_color" />

                    <TextView
                        android:id="@+id/tvSim2Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="SIM 2"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.01"
                        android:fontFamily="sans-serif"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

            </LinearLayout>

            <!-- ══ STATS ROW ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="4dp"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_stat_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="20dp">

                    <TextView
                        android:id="@+id/tvStatSent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/accent"
                        android:textAppearance="@style/TextAppearance.SmsGateway.StatNumber" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="SENT"
                        android:textColor="@color/stat_label"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp"
                    android:background="@drawable/bg_stat_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="20dp">

                    <TextView
                        android:id="@+id/tvStatReceived"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/success"
                        android:textAppearance="@style/TextAppearance.SmsGateway.StatNumber" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="RECEIVED"
                        android:textColor="@color/stat_label"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_stat_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="20dp">

                    <TextView
                        android:id="@+id/tvStatPending"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/warning"
                        android:textAppearance="@style/TextAppearance.SmsGateway.StatNumber" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="PENDING"
                        android:textColor="@color/stat_label"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12" />
                </LinearLayout>
            </LinearLayout>

            <!-- ══ LAST ACTIVITY ══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="LAST ACTIVITY"
                        android:textAppearance="@style/TextAppearance.SmsGateway.SectionLabel" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="↑ "
                            android:textColor="@color/accent"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OUTBOUND"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvLastSent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:fontFamily="monospace"
                        android:text="—"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="14dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="↓ "
                            android:textColor="@color/success"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="INBOUND"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvLastReceived"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="—"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

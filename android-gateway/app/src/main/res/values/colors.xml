<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark navy/silver palette (Bangladesh Police insignia branding) -->
    <!-- Identical to values-night/colors.xml: the app is dark-always now, -->
    <!-- regardless of system day/night setting, matching the Admin app and web console. -->
    <color name="bg_primary">#08111F</color>
    <color name="bg_surface">#0F1D31</color>
    <color name="bg_card">#14253D</color>
    <color name="bg_card_elevated">#1C304B</color>

    <color name="accent">#C7CBD4</color>
    <color name="accent_muted">#8B93A3</color>
    <color name="accent_dim">#1A2433</color>
    <color name="accent_on">#04014B</color>

    <color name="text_primary">#EBF3FF</color>
    <color name="text_secondary">#B2C0D9</color>
    <color name="text_muted">#7F91AF</color>

    <color name="success">#56D88B</color>
    <color name="success_dim">#112F23</color>
    <color name="danger">#FF6D7F</color>
    <color name="danger_dim">#3A1620</color>
    <color name="warning">#FFBF5F</color>
    <color name="warning_dim">#3A2A12</color>

    <color name="sim2_color">#9D8CFF</color>
    <color name="sim2_dim">#2C2552</color>

    <color name="divider">#243A57</color>
    <color name="chip_running_bg">@color/success_dim</color>
    <color name="chip_stopped_bg">@color/danger_dim</color>

    <color name="status_running_glow">#3356D88B</color>
    <color name="status_stopped_glow">#33FF6D7F</color>
    <color name="status_connecting_glow">#33FFBF5F</color>

    <color name="stat_value">@color/text_primary</color>
    <color name="stat_label">@color/text_muted</color>
</resources>

<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SmsGateway" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_muted</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/bg_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="materialButtonStyle">@style/Widget.SmsGateway.Button</item>
        <item name="textInputStyle">@style/Widget.SmsGateway.TextInputLayout</item>
        <item name="tabStyle">@style/Widget.SmsGateway.TabLayout</item>
    </style>

    <style name="Widget.SmsGateway.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Widget.SmsGateway.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Widget.SmsGateway.Button.Hero" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">30dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.SmsGateway.Button.SimInactive" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">30dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:textStyle">bold</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="backgroundTint">@color/bg_card</item>
    </style>

    <style name="Widget.SmsGateway.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/accent</item>
        <item name="hintTextColor">@color/text_muted</item>
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
    </style>

    <style name="Widget.SmsGateway.TabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="android:background">@color/bg_surface</item>
        <item name="tabTextColor">@color/text_muted</item>
        <item name="tabSelectedTextColor">@color/accent</item>
        <item name="tabIndicatorColor">@color/accent</item>
        <item name="tabIndicatorHeight">2dp</item>
        <item name="tabRippleColor">@color/accent_dim</item>
        <item name="tabTextAppearance">@style/TextAppearance.SmsGateway.Tab</item>
    </style>

    <style name="TextAppearance.SmsGateway.Tab" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SmsGateway.SectionLabel" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SmsGateway.CardTitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="TextAppearance.SmsGateway.StatNumber" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">30sp</item>
    </style>

    <style name="TextAppearance.SmsGateway.GatewayId" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/accent</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textSize">12sp</item>
    </style>
</resources>

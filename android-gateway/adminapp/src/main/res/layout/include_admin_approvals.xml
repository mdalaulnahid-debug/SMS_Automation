<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#14253D"
        android:padding="16dp"
        android:text="Live approvals inbox. Requests in NEEDS_MANUAL_REVIEW will appear here with requester, payload, and per-operator dispatch posture."
        android:textColor="#B2C0D9"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/layoutApprovalsList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical" />
</LinearLayout>

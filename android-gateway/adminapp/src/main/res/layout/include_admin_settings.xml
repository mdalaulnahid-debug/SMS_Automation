<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SYSTEM LINK"
        android:textColor="@color/admin_text_dim"
        android:textSize="11sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/admin_bg_panel"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Backend authority and admin key live here so the command surface stays clean."
            android:textColor="@color/admin_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="BACKEND URL"
            android:textColor="@color/admin_text_dim"
            android:textSize="10sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etBackendUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/admin_bg_input"
            android:hint="https://server.example.com"
            android:inputType="textUri"
            android:padding="14dp"
            android:textColor="@color/admin_text_primary"
            android:textColorHint="@color/admin_text_dim" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="ADMIN API KEY"
            android:textColor="@color/admin_text_dim"
            android:textSize="10sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etAdminApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/admin_bg_input"
            android:hint="Admin API key"
            android:inputType="textPassword"
            android:padding="14dp"
            android:textColor="@color/admin_text_primary"
            android:textColorHint="@color/admin_text_dim" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSaveConnection"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Save Link" />

            <Button
                android:id="@+id/btnRefreshData"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="Refresh Live" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="LINK STATUS"
        android:textColor="@color/admin_text_dim"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSettingsSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/admin_bg_panel"
        android:padding="18dp"
        android:text="Use HTTPS when available. Save changes before refreshing live data."
        android:textColor="@color/admin_text_secondary"
        android:textSize="13sp" />
</LinearLayout>
